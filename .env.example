# ============================================
# CALORIE COUNTER - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# --------------------------------------------
# AI SERVICES
# --------------------------------------------

# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative models: mixtral-8x7b-32768, llama2-70b-4096

# --------------------------------------------
# BACKEND - SUPABASE
# --------------------------------------------

# Supabase Project Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase Storage Bucket (for food images)
SUPABASE_STORAGE_BUCKET=food-images

# --------------------------------------------
# NUTRITION DATA API (Optional)
# --------------------------------------------

# USDA FoodData Central API (Free, for nutrition lookup)
# Get your API key from: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your_usda_api_key_here

# Nutritionix API (Alternative, more comprehensive)
# Get your credentials from: https://developer.nutritionix.com/
NUTRITIONIX_APP_ID=your_nutritionix_app_id_here
NUTRITIONIX_APP_KEY=your_nutritionix_app_key_here

# --------------------------------------------
# IMAGE RECOGNITION (Optional)
# --------------------------------------------

# Clarifai Food Recognition API
# Get your API key from: https://www.clarifai.com/
CLARIFAI_API_KEY=your_clarifai_api_key_here

# Google Cloud Vision API (Alternative)
# Get your credentials from: https://console.cloud.google.com/
GOOGLE_CLOUD_VISION_API_KEY=your_google_vision_api_key_here

# --------------------------------------------
# ANALYTICS & MONITORING (Optional)
# --------------------------------------------

# Sentry for Error Tracking
# Get your DSN from: https://sentry.io/
SENTRY_DSN=your_sentry_dsn_here

# PostHog for Product Analytics
# Get your key from: https://posthog.com/
POSTHOG_API_KEY=your_posthog_api_key_here
POSTHOG_HOST=https://app.posthog.com

# --------------------------------------------
# APP CONFIGURATION
# --------------------------------------------

# Environment
NODE_ENV=development
# Options: development, staging, production

# API Base URL (for your own backend if you create one)
API_BASE_URL=http://localhost:3000

# App Version
APP_VERSION=1.0.0

# --------------------------------------------
# FEATURE FLAGS (Optional)
# --------------------------------------------

# Enable/Disable Features
ENABLE_AI_SUGGESTIONS=true
ENABLE_IMAGE_RECOGNITION=false
ENABLE_SOCIAL_FEATURES=false
ENABLE_PREMIUM_FEATURES=false

# --------------------------------------------
# RATE LIMITING & CACHING
# --------------------------------------------

# API Rate Limits (requests per minute)
GROQ_RATE_LIMIT=30
NUTRITION_API_RATE_LIMIT=100

# Cache TTL (in seconds)
NUTRITION_CACHE_TTL=86400
# 86400 = 24 hours

# --------------------------------------------
# SECURITY
# --------------------------------------------

# JWT Secret (for custom auth if needed)
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# Encryption Key (for sensitive data)
ENCRYPTION_KEY=your_encryption_key_here_32_characters_minimum

# --------------------------------------------
# THIRD-PARTY INTEGRATIONS (Future)
# --------------------------------------------

# Apple Health Kit (iOS)
ENABLE_HEALTHKIT=false

# Google Fit (Android)
ENABLE_GOOGLE_FIT=false

# Fitbit Integration
FITBIT_CLIENT_ID=your_fitbit_client_id_here
FITBIT_CLIENT_SECRET=your_fitbit_client_secret_here

# --------------------------------------------
# DEVELOPMENT ONLY
# --------------------------------------------

# Debug Mode
DEBUG=false

# Mock API Responses (for testing without API calls)
USE_MOCK_DATA=false

# Expo Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000
